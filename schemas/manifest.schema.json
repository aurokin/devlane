{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "devlane manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "app",
    "kind",
    "repo",
    "lane",
    "paths",
    "network",
    "ports",
    "compose",
    "outputs",
    "env"
  ],
  "properties": {
    "schema": {
      "type": "integer",
      "const": 1
    },
    "app": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "web",
        "cli",
        "hybrid"
      ]
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "config",
        "branch"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "config": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "mode",
        "stable"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "stable",
            "dev"
          ]
        },
        "stable": {
          "type": "boolean"
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest",
        "stateRoot",
        "cacheRoot",
        "runtimeRoot"
      ],
      "properties": {
        "manifest": {
          "type": "string"
        },
        "composeEnv": {
          "type": [
            "string",
            "null"
          ],
          "description": "Null when the adapter does not declare compose_files."
        },
        "stateRoot": {
          "type": "string"
        },
        "cacheRoot": {
          "type": "string"
        },
        "runtimeRoot": {
          "type": "string"
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectName"
      ],
      "properties": {
        "projectName": {
          "type": "string"
        },
        "publicHost": {
          "type": [
            "string",
            "null"
          ],
          "description": "Null when host_patterns is not declared. When set, rendered from host_patterns.stable or host_patterns.dev based on lane mode."
        },
        "publicUrl": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ports": {
      "type": "object",
      "description": "Keyed by service name. Every service declared in the adapter's ports[] has an entry.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "port",
          "allocated"
        ],
        "properties": {
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535,
            "description": "Allocated port if allocated=true; adapter default if allocated=false (pre-prepare projection)."
          },
          "allocated": {
            "type": "boolean",
            "description": "True when the (app, lane, service) tuple has an entry in the host catalog. False when inspect is computing the manifest before prepare has ever run."
          },
          "healthUrl": {
            "type": [
              "string",
              "null"
            ],
            "description": "Rendered as http://localhost:<port><health_path> when the adapter declares health_path on the port. Null otherwise."
          }
        }
      }
    },
    "compose": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "profiles"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated"
      ],
      "properties": {
        "generated": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "template",
              "destination"
            ],
            "properties": {
              "template": {
                "type": "string"
              },
              "destination": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
