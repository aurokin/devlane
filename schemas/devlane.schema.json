{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "devlane adapter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "app",
    "kind",
    "lane",
    "outputs"
  ],
  "properties": {
    "schema": {
      "type": "integer",
      "const": 1
    },
    "app": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "web",
        "cli",
        "hybrid"
      ]
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_name",
        "stable_branches",
        "project_pattern",
        "path_roots"
      ],
      "properties": {
        "stable_name": {
          "type": "string",
          "minLength": 1
        },
        "stable_branches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "host_patterns": {
          "description": "Optional. When declared, devlane renders hostnames and emits them in the manifest. Omit to use port-based discovery on localhost.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stable": {
              "type": "string",
              "minLength": 1
            },
            "dev": {
              "type": "string",
              "minLength": 1,
              "pattern": ".*\\{lane\\}.*",
              "description": "Must contain the {lane} placeholder so different dev lanes produce different hostnames."
            }
          }
        },
        "project_pattern": {
          "type": "string",
          "minLength": 1
        },
        "path_roots": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "state",
            "cache",
            "runtime"
          ],
          "properties": {
            "state": {
              "type": "string",
              "minLength": 1
            },
            "cache": {
              "type": "string",
              "minLength": 1
            },
            "runtime": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "runtime": {
      "description": "Optional. Declaring compose_files opts into the containerized pattern. Declaring run.commands gives devlane up something to surface for bare-metal apps.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "compose_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "default_profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional_profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        },
        "run": {
          "description": "Optional bare-metal command declarations. When absent, devlane up is a no-op for bare-metal. When present, devlane up either prints the rendered commands (mode: suggest, default) or runs them fire-and-forget (mode: execute).",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "commands"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "suggest",
                "execute"
              ],
              "description": "Defaults to 'suggest' when omitted. devlane init never scaffolds 'execute'; users must opt in consciously."
            },
            "commands": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "name",
                  "command"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
                  },
                  "description": {
                    "type": "string"
                  },
                  "command": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Shell command with {{...}} templating. Scope includes ports.<name>, lane.*, app, runtime.env.*."
                  }
                }
              }
            }
          }
        }
      }
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "default"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
          },
          "default": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "health_path": {
            "type": "string",
            "minLength": 1,
            "description": "Optional HTTP path (e.g., /healthz). When set, the manifest emits a health_url for this port as http://localhost:<port><health_path>."
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_path",
        "generated"
      ],
      "properties": {
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "compose_env_path": {
          "type": "string",
          "minLength": 1,
          "description": "Required when runtime.compose_files is declared. Omit for pure bare-metal or CLI adapters."
        },
        "generated": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "template",
              "destination"
            ],
            "properties": {
              "template": {
                "type": "string",
                "minLength": 1
              },
              "destination": {
                "type": "string",
                "minLength": 1,
                "description": "Must resolve inside the repo root. Absolute paths outside the repo are refused at prepare time."
              }
            }
          }
        }
      }
    }
  }
}
