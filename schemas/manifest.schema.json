{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "devlane manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "app",
    "kind",
    "ready",
    "lane",
    "paths",
    "network",
    "ports",
    "compose",
    "outputs"
  ],
  "properties": {
    "schema": {
      "type": "integer",
      "const": 1
    },
    "app": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "web",
        "cli",
        "hybrid"
      ]
    },
    "ready": {
      "type": "boolean",
      "description": "True when every adapter-declared service has a committed host-port allocation for this lane."
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "mode",
        "stable",
        "branch",
        "repoRoot",
        "configPath"
      ],
      "description": "Identity of this lane. Merges the old top-level 'repo' object into 'lane' so every identity field lives in one place.",
      "properties": {
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string",
          "description": "Deterministic lane slug. See docs/20-concepts.md for the contract algorithm used for lane-derived slugs."
        },
        "mode": {
          "type": "string",
          "enum": [
            "stable",
            "dev"
          ]
        },
        "stable": {
          "type": "boolean"
        },
        "branch": {
          "type": "string"
        },
        "repoRoot": {
          "type": "string",
          "description": "Absolute Git worktree root for the current checkout."
        },
        "configPath": {
          "type": "string",
          "description": "Absolute path to the active devlane.yaml. adapterRoot is the directory containing this file."
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest",
        "stateRoot",
        "cacheRoot",
        "runtimeRoot"
      ],
      "description": "composeEnv is present only when the adapter declares compose_files; otherwise the key is omitted.",
      "properties": {
        "manifest": {
          "type": "string"
        },
        "composeEnv": {
          "type": "string"
        },
        "stateRoot": {
          "type": "string"
        },
        "cacheRoot": {
          "type": "string"
        },
        "runtimeRoot": {
          "type": "string"
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectName"
      ],
      "properties": {
        "projectName": {
          "type": "string"
        },
        "publicHost": {
          "type": [
            "string",
            "null"
          ],
          "description": "Null when host_patterns is not declared. When set, rendered from host_patterns.stable or host_patterns.dev based on lane mode."
        },
        "publicUrl": {
          "type": [
            "string",
            "null"
          ],
          "description": "Convenience field: http://<publicHost> when publicHost is set, null otherwise."
        }
      }
    },
    "ports": {
      "type": "object",
      "description": "Host-port state for every adapter-declared service. Empty when the adapter declares no ports.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "port",
          "allocated",
          "healthUrl"
        ],
        "properties": {
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "allocated": {
            "type": "boolean"
          },
          "healthUrl": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "compose": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "profiles"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated"
      ],
      "properties": {
        "generated": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "template",
              "destination"
            ],
            "properties": {
              "template": {
                "type": "string"
              },
              "destination": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
