{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "devlane manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "app",
    "kind",
    "ready",
    "lane",
    "paths",
    "network",
    "ports",
    "compose",
    "outputs"
  ],
  "properties": {
    "schema": {
      "type": "integer",
      "const": 1
    },
    "app": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "web",
        "cli",
        "hybrid"
      ]
    },
    "ready": {
      "type": "boolean",
      "description": "True iff the catalog has entries for every declared port (equivalently, every ports.*.allocated is true). Does not claim bindability or running state. When the adapter declares no ports, ready is true (no allocations to wait on). Fresh when emitted by inspect --json; snapshot when read from .devlane/manifest.json on disk."
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "mode",
        "stable",
        "branch",
        "repoRoot",
        "configPath"
      ],
      "description": "Identity of this lane. Merges the old top-level 'repo' object into 'lane' so every identity field lives in one place.",
      "properties": {
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "stable",
            "dev"
          ]
        },
        "stable": {
          "type": "boolean"
        },
        "branch": {
          "type": "string"
        },
        "repoRoot": {
          "type": "string"
        },
        "configPath": {
          "type": "string"
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest",
        "stateRoot",
        "cacheRoot",
        "runtimeRoot"
      ],
      "description": "composeEnv is present only when the adapter declares compose_files; otherwise the key is omitted.",
      "properties": {
        "manifest": {
          "type": "string"
        },
        "composeEnv": {
          "type": "string"
        },
        "stateRoot": {
          "type": "string"
        },
        "cacheRoot": {
          "type": "string"
        },
        "runtimeRoot": {
          "type": "string"
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectName"
      ],
      "properties": {
        "projectName": {
          "type": "string"
        },
        "publicHost": {
          "type": [
            "string",
            "null"
          ],
          "description": "Null when host_patterns is not declared. When set, rendered from host_patterns.stable or host_patterns.dev based on lane mode."
        },
        "publicUrl": {
          "type": [
            "string",
            "null"
          ],
          "description": "Convenience field: http://<publicHost> when publicHost is set, null otherwise."
        }
      }
    },
    "ports": {
      "type": "object",
      "description": "Keyed by service name. Every service declared in the adapter's ports[] has an entry.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "port",
          "allocated"
        ],
        "properties": {
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535,
            "description": "Allocated port if allocated=true. When allocated=false, this is a provisional value: stable lanes emit their fixture (stable_port when declared, otherwise default); dev lanes emit the current best candidate computed against the live catalog using the allocator rules. Provisional values are not reserved and may still change before prepare publishes an allocation."
          },
          "allocated": {
            "type": "boolean",
            "description": "True when the (app, lane, service) tuple has an entry in the host catalog. False when inspect is computing the manifest before prepare has ever run."
          },
          "healthUrl": {
            "type": [
              "string",
              "null"
            ],
            "description": "Rendered as http://localhost:<port><health_path> when the adapter declares health_path on the port. Null otherwise."
          }
        }
      }
    },
    "compose": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "profiles"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated"
      ],
      "properties": {
        "generated": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "template",
              "destination"
            ],
            "properties": {
              "template": {
                "type": "string"
              },
              "destination": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
